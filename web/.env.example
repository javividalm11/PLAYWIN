# ═══════════ PLAYWIN — Variables de entorno ═══════════
# Copia este archivo a .env.local y rellena los valores.

# ── Supabase (supabase.com → tu proyecto → Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ⚠️ Secreta, solo servidor (nunca NEXT_PUBLIC):
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin bootstrap ──
# Correos (separados por coma) que tendrán acceso al dashboard /admin
ADMIN_EMAILS=Javier.Vidal@aegisai.co

# ── Paddle (pagos) — sandbox-vendors.paddle.com ──
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Price ID del plan mensual de $9 creado en Paddle → Catalog → Products
NEXT_PUBLIC_PADDLE_PRICE_ID=
# Notifications → Webhooks → secret key
PADDLE_WEBHOOK_SECRET=
